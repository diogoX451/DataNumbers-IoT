{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "IoT Command Send",
  "type": "object",
  "properties": {
    "event_id": {
      "type": "string",
      "format": "uuid"
    },
    "actuator_id": {
      "type": "string",
      "format": "uuid"
    },
    "device_id": {
      "type": "string",
      "format": "uuid"
    },
    "command_topic": {
      "type": "string"
    },
    "payload": {
      "type": "object"
    },
    "timestamp": {
      "type": "string",
      "format": "date-time"
    }
  },
  "required": ["event_id", "actuator_id", "device_id", "command_topic", "payload", "timestamp"]
}
